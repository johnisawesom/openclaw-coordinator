{
  "name": "openclaw-coordinator",
  "version": "1.0.0",
  "description": "OpenClaw coordinator: queries Qdrant errors → calls Claude → creates GitHub PRs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@octokit/core": "^6.1.2",
    "@octokit/plugin-retry": "^7.1.1",
    "@octokit/plugin-throttling": "^9.3.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "dotenv": "^16.4.5",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
